---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Panel de Administración - GE Abogados">
    <!-- Quill CSS & JS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js" is:inline></script>
    
    <div class="min-h-screen bg-[var(--color-bg)] flex itmes-start justify-center py-20 px-4 pt-32" id="app-container">
        
        <!-- Vista de Login -->
        <div id="login-view" class="w-full max-w-md bg-white p-8 border border-gray-200 shadow-2xl mx-auto my-auto self-center">
            <div class="text-center mb-10">
                <h1 class="text-3xl font-serif text-[var(--color-primary-dark)] mb-2">Acceso Restringido</h1>
                <p class="text-gray-500 font-sans text-sm">Ingrese sus credenciales administrativas</p>
            </div>
            
            <form id="login-form" class="space-y-6">
                <div>
                    <label class="block font-sans text-sm tracking-widest text-gray-500 mb-2 uppercase">Correo Electrónico</label>
                    <input type="email" id="email" required class="w-full border-b border-gray-300 py-3 bg-transparent text-[var(--color-primary-dark)] focus:outline-none focus:border-[var(--color-accent-gold)] transition-colors">
                </div>
                <div>
                    <label class="block font-sans text-sm tracking-widest text-gray-500 mb-2 uppercase">Contraseña</label>
                    <input type="password" id="password" required class="w-full border-b border-gray-300 py-3 bg-transparent text-[var(--color-primary-dark)] focus:outline-none focus:border-[var(--color-accent-gold)] transition-colors">
                </div>
                
                <div id="login-error" class="hidden text-red-500 text-sm font-sans mt-2">Credenciales inválidas</div>
                
                <button type="submit" class="w-full btn-editorial text-center block" style="margin-top: 2rem;">
                    <span class="relative z-10 transition-colors duration-500 group-hover:text-white uppercase tracking-widest text-sm">
                        Ingresar
                    </span>
                </button>
            </form>
        </div>

        <!-- Vista de Dashboard (Editor de Blog + Historial) -->
        <div id="dashboard-view" class="w-full max-w-7xl hidden grid grid-cols-1 lg:grid-cols-4 gap-8 items-start">
            
            <!-- Sidebar: Historial -->
            <div class="col-span-1 bg-white p-6 border border-gray-200 shadow-xl h-[80vh] overflow-y-auto">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-gray-100">
                    <h2 class="text-xl font-serif text-[var(--color-primary-dark)]">Historial</h2>
                    <button id="btn-new-post" class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent-gold)]">+ Nuevo</button>
                </div>
                <div id="posts-list" class="space-y-4">
                    <p class="text-xs text-gray-400 italic font-sans">Cargando entradas...</p>
                </div>
                <div class="mt-12 pt-4 border-t border-gray-100 text-center">
                    <button id="logout-btn" class="text-xs font-sans uppercase tracking-widest text-red-500 hover:text-red-700 transition-colors">Cerrar Sesión</button>
                </div>
            </div>

            <!-- Formulario Principal -->
            <div class="col-span-1 lg:col-span-3 bg-white p-8 border border-gray-200 shadow-2xl">
                <div class="flex justify-between items-center mb-10 border-b border-gray-200 pb-4">
                    <h1 id="editor-title" class="text-3xl font-serif text-[var(--color-primary-dark)]">Nueva Entrada</h1>
                </div>
                
                <form id="blog-form" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="block font-sans text-sm tracking-widest text-gray-500 mb-2 uppercase">Título del Artículo</label>
                            <input type="text" id="blog-title" required class="w-full border border-gray-300 p-3 bg-transparent text-[var(--color-primary-dark)] focus:outline-none focus:border-[var(--color-accent-gold)] transition-colors">
                        </div>
                        <div>
                            <label class="block font-sans text-sm tracking-widest text-gray-500 mb-2 uppercase">Categoría</label>
                            <select id="blog-category" class="w-full border border-gray-300 p-3 bg-transparent text-[var(--color-primary-dark)] focus:outline-none focus:border-[var(--color-accent-gold)] transition-colors">
                                <option value="Derecho Penal">Derecho Penal</option>
                                <option value="Derecho Corporativo">Derecho Corporativo</option>
                                <option value="Derecho Administrativo">Derecho Administrativo</option>
                                <option value="Derecho Laboral">Derecho Laboral</option>
                                <option value="Actualidad Legal">Actualidad Legal</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block font-sans text-sm tracking-widest text-gray-500 mb-2 uppercase">URL de Imagen Principal</label>
                        <input type="url" id="blog-image" placeholder="https://ejemplo.com/imagen.jpg" class="w-full border border-gray-300 p-3 bg-transparent text-[var(--color-primary-dark)] focus:outline-none focus:border-[var(--color-accent-gold)] transition-colors">
                    </div>

                    <div>
                        <label class="block font-sans text-sm tracking-widest text-gray-500 mb-2 uppercase">Resumen Breve (Saldrá en la Portada)</label>
                        <textarea id="blog-summary" rows="2" maxlength="200" required class="w-full border border-gray-300 p-3 bg-transparent text-[var(--color-primary-dark)] focus:outline-none focus:border-[var(--color-accent-gold)] transition-colors"></textarea>
                    </div>

                    <div class="mb-12">
                        <label class="block font-sans text-sm tracking-widest text-gray-500 mb-2 uppercase">Contenido del Blog</label>
                        <!-- Quill Editor Container -->
                        <div id="quill-editor" style="height: 300px;"></div>
                    </div>
                    
                    <div class="flex items-center space-x-3 mt-4">
                        <input type="checkbox" id="blog-published" class="w-5 h-5 accent-[var(--color-accent-gold)] cursor-pointer">
                        <label for="blog-published" class="font-sans text-sm text-gray-700 cursor-pointer">Publicar / Hacer visible en portada</label>
                    </div>
                    
                    <div id="blog-status" class="hidden text-sm font-sans mt-2"></div>

                    <div class="pt-6 border-t border-gray-200 flex justify-between items-center">
                        <button type="button" id="btn-delete-post" class="hidden text-xs text-red-500 hover:text-red-700 uppercase tracking-widest font-bold">Eliminar Entrada</button>
                        
                        <button type="submit" id="submit-blog" class="btn-editorial text-center w-64 max-w-full ml-auto">
                            <span class="relative z-10 transition-colors duration-500 group-hover:text-white uppercase tracking-widest text-sm">
                                Guardar Artículo
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <style is:inline>
        /* Modificar el estilo por defecto de Quill para darle toque Editorial */
        .ql-toolbar.ql-snow { border-color: #d1d5db; background: #FDFBF7; }
        .ql-container.ql-snow { border-color: #d1d5db; font-family: 'Montserrat', sans-serif; font-size: 1rem; }
        .ql-editor { padding: 1rem; color: #111827; }
        .ql-editor p { margin-bottom: 1em; }
        .ql-editor h1, .ql-editor h2, .ql-editor h3 { font-family: 'Playfair Display', serif; margin-bottom: 0.5em; }
    </style>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const API_BASE = 'https://app.geabogados.com.co/api/v1';
            let currentBlogId = null;
            let currentBlogsList = [];
            
            // Inicializar Quill JS
            var quill = new Quill('#quill-editor', {
                theme: 'snow',
                placeholder: 'Escriba aquí el contenido del análisis jurídico...',
                modules: {
                    toolbar: [
                        [{ 'header': [2, 3, false] }],
                        ['bold', 'italic', 'underline', 'strike'],
                        ['blockquote', 'code-block'],
                        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                        [{ 'color': [] }, { 'background': [] }],
                        ['link', 'image', 'video'],
                        ['clean']
                    ]
                }
            });

            const loginView = document.getElementById('login-view');
            const dashboardView = document.getElementById('dashboard-view');
            const loginForm = document.getElementById('login-form');
            const blogForm = document.getElementById('blog-form');
            const logoutBtn = document.getElementById('logout-btn');
            const loginError = document.getElementById('login-error');
            const blogStatus = document.getElementById('blog-status');
            const postsList = document.getElementById('posts-list');
            const btnNewPost = document.getElementById('btn-new-post');
            const btnDeletePost = document.getElementById('btn-delete-post');

            // --- AUTH ---
            const token = localStorage.getItem('ge_auth_token');
            if (token) {
                showDashboard();
                loadBlogHistory();
            }

            function showDashboard() {
                loginView.classList.add('hidden');
                dashboardView.classList.remove('hidden');
            }

            function showLogin() {
                localStorage.removeItem('ge_auth_token');
                dashboardView.classList.add('hidden');
                loginView.classList.remove('hidden');
            }

            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const email = document.getElementById('email').value;
                const password = document.getElementById('password').value;
                loginError.classList.add('hidden');

                try {
                    const res = await fetch(`${API_BASE}/auth/login/`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email, password })
                    });
                    
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.detail || 'Imposible entrar');
                    
                    localStorage.setItem('ge_auth_token', data.access_token);
                    showDashboard();
                    loadBlogHistory();
                } catch (error) {
                    loginError.textContent = error.message;
                    loginError.classList.remove('hidden');
                }
            });

            logoutBtn.addEventListener('click', showLogin);

            // --- FUNCTIONALITY ---
            function generateSlug(title) {
                return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
            }

            function setFormState(blog = null) {
                blogStatus.classList.add('hidden');
                if (blog) {
                    currentBlogId = blog.id;
                    document.getElementById('editor-title').textContent = 'Editar Entrada';
                    document.getElementById('blog-title').value = blog.title || '';
                    document.getElementById('blog-category').value = blog.category || 'Derecho Penal';
                    document.getElementById('blog-image').value = blog.image_url || '';
                    document.getElementById('blog-summary').value = blog.summary || '';
                    document.getElementById('blog-published').checked = blog.is_published;
                    quill.root.innerHTML = blog.content || '';
                    btnDeletePost.classList.remove('hidden');
                } else {
                    currentBlogId = null;
                    document.getElementById('editor-title').textContent = 'Nueva Entrada';
                    blogForm.reset();
                    quill.root.innerHTML = '';
                    btnDeletePost.classList.add('hidden');
                }
            }

            btnNewPost.addEventListener('click', () => setFormState(null));

            async function loadBlogHistory() {
                try {
                    const res = await fetch(`${API_BASE}/blogs/?public_only=false`, {
                        headers: { 'Authorization': `Bearer ${localStorage.getItem('ge_auth_token')}` }
                    });
                    
                    if (res.status === 401) { showLogin(); return; }
                    
                    const data = await res.json();
                    currentBlogsList = Array.isArray(data) ? data : (data.items || []);
                    
                    postsList.innerHTML = '';
                    if (currentBlogsList.length === 0) {
                        postsList.innerHTML = '<p class="text-xs text-gray-400 italic font-sans">No hay entradas.</p>';
                        return;
                    }
                    
                    currentBlogsList.forEach(blog => {
                        const div = document.createElement('div');
                        div.className = 'p-3 border border-gray-100 rounded hover:bg-gray-50 cursor-pointer transition-colors';
                        const pubTag = blog.is_published ? '<span class="text-[10px] bg-green-100 text-green-800 px-1 rounded ml-2">Pub</span>' : '<span class="text-[10px] bg-yellow-100 text-yellow-800 px-1 rounded ml-2">Borr</span>';
                        div.innerHTML = `
                            <div class="flex justify-between items-start">
                                <p class="text-sm font-serif font-bold text-[var(--color-primary-dark)] truncate tooltip flex-1">${blog.title}</p>
                                <a href="/blog/?s=${blog.slug}" target="_blank" class="ml-2 text-[10px] text-[var(--color-accent-gold)] hover:underline">Ver ↗</a>
                            </div>
                            <p class="text-[10px] text-gray-500 uppercase tracking-wider mt-1">${new Date(blog.created_at).toLocaleDateString()}${pubTag}</p>
                        `;
                        div.addEventListener('click', () => setFormState(blog));
                        postsList.appendChild(div);
                    });
                } catch (error) {
                    console.error("No se pudo cargar el historial", error);
                }
            }

            blogForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const title = document.getElementById('blog-title').value;
                const token = localStorage.getItem('ge_auth_token');
                
                const payload = {
                    title: title,
                    slug: generateSlug(title),
                    category: document.getElementById('blog-category').value,
                    summary: document.getElementById('blog-summary').value,
                    content: quill.root.innerHTML, // Recoger HTML de Quill
                    image_url: document.getElementById('blog-image').value || null,
                    is_published: document.getElementById('blog-published').checked
                };

                const btn = document.getElementById('submit-blog');
                const btnText = btn.querySelector('span');
                btnText.textContent = 'Guardando...';
                btn.disabled = true;
                
                blogStatus.classList.remove('hidden', 'text-green-600', 'text-red-600');
                blogStatus.classList.add('text-[var(--color-primary-dark)]');
                blogStatus.textContent = 'Procesando...';

                try {
                    const method = currentBlogId ? 'PUT' : 'POST';
                    const endpoint = currentBlogId ? `${API_BASE}/blogs/${currentBlogId}` : `${API_BASE}/blogs/`;

                    const res = await fetch(endpoint, {
                        method: method,
                        headers: { 
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${token}`
                        },
                        body: JSON.stringify(payload)
                    });
                    
                    if (res.status === 401 || res.status === 403) throw new Error("Sesión expirada o faltan permisos.");
                    if (!res.ok) {
                        const errData = await res.json();
                        throw new Error(errData.detail || 'Error interno del servidor.');
                    }
                    
                    blogStatus.textContent = currentBlogId ? "✅ Artículo actualizado correctamente." : "✅ Artículo creado de forma exitosa.";
                    blogStatus.classList.add('text-green-600');
                    blogStatus.classList.remove('text-[var(--color-primary-dark)]');
                    
                    if (!currentBlogId) setFormState(null); // Clear form si es uno nuevo
                    loadBlogHistory(); // Refrescar historial
                    
                } catch (error) {
                    blogStatus.textContent = `❌ Error: ${error.message}`;
                    blogStatus.classList.add('text-red-600');
                    blogStatus.classList.remove('text-[var(--color-primary-dark)]');
                } finally {
                    btnText.textContent = 'Guardar Artículo';
                    btn.disabled = false;
                }
            });

            btnDeletePost.addEventListener('click', async () => {
                if (!currentBlogId) return;
                const token = localStorage.getItem('ge_auth_token');
                if (confirm('¿Está seguro de eliminar esta entrada? Esta acción no se puede deshacer.')) {
                    try {
                        const res = await fetch(`${API_BASE}/blogs/${currentBlogId}`, {
                            method: 'DELETE',
                            headers: { 'Authorization': `Bearer ${token}` }
                        });
                        if (!res.ok) throw new Error('Error al eliminar');
                        setFormState(null);
                        loadBlogHistory();
                        alert('Entrada eliminada.');
                    } catch (error) {
                        alert(`❌ Falló la eliminación: ${error.message}`);
                    }
                }
            });
        });
    </script>
</Layout>
