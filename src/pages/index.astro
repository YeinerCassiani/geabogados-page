    <script>
        // Fetch Blogs dynamically
        async function fetchDynamicBlogs() {
            try {
                const res = await fetch('https://app.geabogados.com.co/api/v1/blogs/');
                if (!res.ok) return;
                const blogs = await res.json();
                const container = document.getElementById('dynamic-blogs-container');
                if (container && blogs && blogs.length > 0) {
                    container.innerHTML = ''; // Limpiar skeletons
                    blogs.slice(0, 4).forEach(blog => {
                        const date = new Date(blog.created_at).toLocaleDateString('es-ES', {day: 'numeric', month: 'short'});
                        const image = blog.image_url || 'https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&w=400&q=80';
                        const cat = blog.category || 'Análisis';
                        
                        container.innerHTML += `
                        <a href="/blog/?s=${blog.slug}" class="group relative block transition-transform hover:-translate-y-1">
                            <article class="relative cursor-pointer">
                                <div class="aspect-[4/3] overflow-hidden mb-6">
                                    <img src="${image}" 
                                         alt="${blog.title}" loading="lazy"
                                         class="w-full h-full object-cover grayscale opacity-90 transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105">
                                </div>
                                <div>
                                    <p class="text-xs uppercase tracking-widest text-[var(--color-accent-gold)] font-bold mb-3">${date} / ${cat}</p>
                                    <h3 class="text-lg font-serif font-bold text-[var(--color-primary-dark)] leading-snug group-hover:text-[var(--color-accent-gold)] transition-colors">
                                        ${blog.title}
                                    </h3>
                                </div>
                            </article>
                        </a>`;
                    });
                } else if (container) {
                    container.innerHTML = '<p class="text-sm font-sans font-light italic text-gray-500">Aún no hay publicaciones disponibles.</p>';
                }
            } catch (error) {
                console.error("Error al cargar blogs", error);
            }
        }

