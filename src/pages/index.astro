                if (heroImage) {
                    setTimeout(() => {
                        heroImage.classList.add('animate-fade-in-right');
                        heroImage.style.opacity = '1';
                    }, 300);
                }
            }, 100);

            // Parallax effect
            let ticking = false;
            
            function updateParallax() {
                const windowHeight = window.innerHeight;
                const parallaxElements = document.querySelectorAll('.parallax-element');
                
                parallaxElements.forEach((element) => {
                    const parent = element.parentElement;
                    if (!parent) return;
                    
                    const rect = parent.getBoundingClientRect();
                    
                    // Solo aplicar calcular si está en el viewport
                    if (rect.top <= windowHeight && rect.bottom >= 0) {
                        const elementCenter = rect.top + (rect.height / 2);
                        const viewportCenter = windowHeight / 2;
                        // Invertimos la distancia para que vaya más lento y con efecto parallax natural
                        const distance = viewportCenter - elementCenter;
                        
                        const rate = distance * 0.05; // Efecto sutil para evitar bordes al reducir el zoom
                        element.style.transform = `translate3d(0, ${rate}px, 0)`; // GPU accelerated
                    }
                });
                
                ticking = false;
            }
            
            function requestTick() {
                if (!ticking) {
                    requestAnimationFrame(updateParallax);
                    ticking = true;
                }
            }
            
            window.addEventListener('scroll', requestTick);

            // Scroll to top button functionality
