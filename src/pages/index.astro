---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="GE ABOGADOS - Firma Legal de Élite | Especialistas en Derecho Penal y Corporativo"
    description="Firma legal liderada por Giovany Escobar, brindando asesoramiento premium y defensa estratégica en casos de alta complejidad, derecho penal y corportativo."
>
    <!-- Navigation (Editorial) -->
    <nav class="fixed w-full top-0 z-50 transition-all duration-300 bg-[var(--color-primary-light)]/90 backdrop-blur-md border-b border-gray-200/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center">
                    <img src="/logo2.png" alt="GE Abogados" class="h-10 w-auto opacity-90 mix-blend-multiply">
                </div>
                <div class="hidden md:flex items-center space-x-10">
                    <a href="#home" class="text-xs tracking-widest uppercase font-semibold text-[var(--color-primary-dark)] link-underline" data-translate="nav-home">INICIO</a>
                    <a href="#services" class="text-xs tracking-widest uppercase font-semibold text-[var(--color-primary-dark)] link-underline" data-translate="nav-services">SERVICIOS</a>
                    <a href="#about" class="text-xs tracking-widest uppercase font-semibold text-[var(--color-primary-dark)] link-underline" data-translate="nav-about">NOSOTROS</a>
                    <a href="#blog" class="text-xs tracking-widest uppercase font-semibold text-[var(--color-primary-dark)] link-underline" data-translate="nav-blog">BLOG</a>
                    <a href="https://api.whatsapp.com/send?phone=573104273850&text=Hola,%20quisiera%20información%20sobre%20sus%20servicios%20legales" target="_blank" class="btn-editorial px-6 py-2.5 text-xs tracking-wider uppercase font-bold">
                        <span data-translate="nav-contact">CONTACTAR</span>
                    </a>
                    <button id="langToggle" class="text-xs font-bold text-[var(--color-primary-dark)] hover:text-[var(--color-accent-gold)] transition-colors ml-2 uppercase tracking-widest">
                        EN
                    </button>
                </div>
                <div class="md:hidden">
                    <button class="text-[var(--color-primary-dark)] focus:outline-none" id="mobile-menu-btn" aria-label="Abrir menú de navegación" aria-expanded="false">
                        <i class="fas fa-bars text-2xl" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section (Editorial) -->
    <section id="home" class="noise-bg pt-24 min-h-screen flex items-center relative overflow-hidden">
        <!-- Subtle Grid Lines -->
        <div class="absolute inset-0 pointer-events-none opacity-10 flex justify-center">
            <div class="w-full max-w-7xl h-full border-x border-[var(--color-primary-dark)] flex">
                <div class="flex-1 border-r border-[var(--color-primary-dark)]"></div>
                <div class="flex-1 border-r border-[var(--color-primary-dark)] hidden md:block"></div>
                <div class="flex-1 hidden md:block"></div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
                
                <div class="col-span-1 lg:col-span-7 hero-content opacity-0 mt-12 lg:mt-0">
                    <div class="inline-block border-b border-[var(--color-primary-dark)] pb-2 mb-8 animate-fade-in-up" style="animation-delay: 0.2s;">
                        <span class="text-xs tracking-[0.2em] uppercase font-bold text-[var(--color-primary-dark)] pr-8">Firma Legal</span>
                    </div>
                    
                    <h1 class="text-5xl lg:text-7xl font-serif text-[var(--color-primary-dark)] mb-8 leading-[1.1] tracking-tight animate-fade-in-up" data-translate="hero-title" style="animation-delay: 0.4s;">
                        EXCELENCIA<br>
                        <span class="italic text-[var(--color-accent-gold)] font-light">&</span> AUTORIDAD
                    </h1>
                    
                    <p class="text-lg lg:text-xl text-[var(--color-text-body)] mb-12 max-w-lg font-light leading-relaxed animate-fade-in-up" data-translate="hero-subtitle" style="animation-delay: 0.6s;">
                        Defensa estratégica y asesoramiento premium para resolver asuntos legales complejos con rigor y discreción absoluta.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row gap-6 animate-fade-in-up" style="animation-delay: 0.8s;">
                        <a id="btn-agendar" href="https://api.whatsapp.com/send?phone=573104273850&text=Hola,%20quisiera%20agendar%20una%20consulta%20legal" target="_blank" rel="noopener noreferrer" class="btn-editorial px-10 py-4 text-sm tracking-widest uppercase font-bold text-center group">
                            <span data-translate="hero-schedule">AGENDAR CONSULTA</span>
                        </a>
                        <a href="#services" class="btn-editorial-outline px-10 py-4 text-sm tracking-widest uppercase font-bold text-center" data-translate="hero-connect">
                            DESCUBRIR SERVICIOS
                        </a>
                    </div>
                </div>
                
                <div class="col-span-1 lg:col-span-5 relative mt-16 lg:mt-0 hero-image opacity-0">
                    <div class="relative overflow-hidden aspect-[3/4] p-2 border border-[var(--color-primary-dark)]/20 animate-reveal" style="animation-delay: 0.5s;">
                        <!-- Logo watermark -->
                        <div class="absolute inset-0 flex items-center justify-center z-0 opacity-5">
                            <img src="/logo2.png" alt="" class="w-64 h-64 object-contain">
                        </div>
                        
                        <!-- Giovany Portrait -->
                        <div class="relative w-full h-full overflow-hidden bg-[var(--color-primary-dark)]">
                            <img src="/giovany.png" 
                                 alt="Abogado profesional" 
                                 class="absolute -top-[5%] left-0 w-full h-[110%] object-cover object-top opacity-90 grayscale contrast-125 transition-all duration-700 hover:grayscale-0 animate-scale z-10 parallax-element">
                        </div>
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-[var(--color-primary-dark)] text-[var(--color-primary-light)] p-6 z-20 animate-fade-in-up" style="animation-delay: 1.2s; max-width: 250px;">
                        <p class="font-serif text-lg italic mb-2">"El rigor jurídico como principio."</p>
                        <p class="text-xs uppercase tracking-widest text-[var(--color-accent-gold)]">Giovany Escobar</p>
                    </div>
                </div>
                
            </div>
        </div>
    </section>


    <!-- Practice Areas (Editorial Spread) -->
    <section id="services" class="py-24 bg-[var(--color-primary-light)] relative border-t border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 pb-8 border-b-2 border-[var(--color-primary-dark)]">
                <div>
                    <span class="text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-accent-gold)] block mb-4">Especialidades</span>
                    <h2 class="text-4xl md:text-5xl font-serif text-[var(--color-primary-dark)]" data-translate="practice-areas-title">ÁREAS DE PRÁCTICA</h2>
                </div>
                <div class="mt-6 md:mt-0 max-w-sm">
                    <p class="text-[var(--color-text-body)] text-sm leading-relaxed">
                        Abordamos cada caso con meticulosidad quirúrgica, ofreciendo representación de élite en las ramas más críticas del derecho.
                    </p>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0 border-l border-[var(--color-primary-dark)]/10">
                <!-- Service 1 -->
                <div class="p-8 md:p-12 border-b border-r border-[var(--color-primary-dark)]/10 group hover:bg-white transition-colors duration-500 editorial-hover">
                    <span class="text-4xl font-serif font-light text-[var(--color-primary-dark)]/20 mb-6 block group-hover:text-[var(--color-accent-gold)] transition-colors">01</span>
                    <h3 class="text-xl font-bold tracking-wide uppercase text-[var(--color-primary-dark)] mb-4" data-translate="service-1-title">DERECHO PENAL</h3>
                    <p class="text-[var(--color-text-body)] font-light leading-relaxed text-sm" data-translate="service-1-desc">
                        Defensa penal integral en procesos judiciales. Asesoramiento en investigaciones preliminares y representación en todas las instancias.
                    </p>
                </div>
                <!-- Service 2 -->
                <div class="p-8 md:p-12 border-b border-r border-[var(--color-primary-dark)]/10 group hover:bg-white transition-colors duration-500 editorial-hover">
                    <span class="text-4xl font-serif font-light text-[var(--color-primary-dark)]/20 mb-6 block group-hover:text-[var(--color-accent-gold)] transition-colors">02</span>
                    <h3 class="text-xl font-bold tracking-wide uppercase text-[var(--color-primary-dark)] mb-4" data-translate="service-2-title">DERECHO NOTARIAL</h3>
                    <p class="text-[var(--color-text-body)] font-light leading-relaxed text-sm" data-translate="service-2-desc">
                        Servicios notariales especializados. Escrituras públicas, autenticaciones y todos los actos notariales con extrema precisión legal.
                    </p>
                </div>
                <!-- Service 3 -->
                <div class="p-8 md:p-12 border-b lg:border-r border-[var(--color-primary-dark)]/10 group hover:bg-white transition-colors duration-500 editorial-hover">
                    <span class="text-4xl font-serif font-light text-[var(--color-primary-dark)]/20 mb-6 block group-hover:text-[var(--color-accent-gold)] transition-colors">03</span>
                    <h3 class="text-xl font-bold tracking-wide uppercase text-[var(--color-primary-dark)] mb-4" data-translate="service-3-title">ADMINISTRATIVO</h3>
                    <p class="text-[var(--color-text-body)] font-light leading-relaxed text-sm" data-translate="service-3-desc">
                        Asesoramiento en procedimientos frente al Estado. Contratación pública, licencias y protección ante acciones gubernamentales.
                    </p>
                </div>
                <!-- Service 4 -->
                <div class="p-8 md:p-12 border-b md:border-b-0 border-r border-[var(--color-primary-dark)]/10 group hover:bg-white transition-colors duration-500 editorial-hover">
                    <span class="text-4xl font-serif font-light text-[var(--color-primary-dark)]/20 mb-6 block group-hover:text-[var(--color-accent-gold)] transition-colors">04</span>
                    <h3 class="text-xl font-bold tracking-wide uppercase text-[var(--color-primary-dark)] mb-4" data-translate="service-4-title">EXTRADICIÓN</h3>
                    <p class="text-[var(--color-text-body)] font-light leading-relaxed text-sm" data-translate="service-4-desc">
                        Especialización en procesos de extradición internacional. Defensa estratégica avanzada en procedimientos de cooperación judicial.
                    </p>
                </div>
                <!-- Service 5 -->
                <div class="p-8 md:p-12 border-b md:border-b-0 border-r border-[var(--color-primary-dark)]/10 group hover:bg-white transition-colors duration-500 editorial-hover">
                    <span class="text-4xl font-serif font-light text-[var(--color-primary-dark)]/20 mb-6 block group-hover:text-[var(--color-accent-gold)] transition-colors">05</span>
                    <h3 class="text-xl font-bold tracking-wide uppercase text-[var(--color-primary-dark)] mb-4" data-translate="service-5-title">DERECHO LABORAL</h3>
                    <p class="text-[var(--color-text-body)] font-light leading-relaxed text-sm" data-translate="service-5-desc">
                        Estructuración de relaciones laborales. Gestión de riesgos patrimoniales derivados de conflictos laborales y negociaciones.
                    </p>
                </div>
                <!-- Service 6 -->
                <div class="p-8 md:p-12 border-r border-[var(--color-primary-dark)]/10 group hover:bg-white transition-colors duration-500 editorial-hover">
                    <span class="text-4xl font-serif font-light text-[var(--color-primary-dark)]/20 mb-6 block group-hover:text-[var(--color-accent-gold)] transition-colors">06</span>
                    <h3 class="text-xl font-bold tracking-wide uppercase text-[var(--color-primary-dark)] mb-4" data-translate="service-6-title">COBROS TÁCTICOS</h3>
                    <p class="text-[var(--color-text-body)] font-light leading-relaxed text-sm" data-translate="service-6-desc">
                        Gestión contundente de reclamaciones y recuperación de cartera. Protección de activos y resolución efectiva de litigios patrimoniales.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Statement / Straight Talk -->
    <section class="py-24 bg-[var(--color-primary-dark)] text-[var(--color-primary-light)]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                <div class="col-span-1 lg:col-span-5 relative">
                    <div class="relative aspect-[4/5] overflow-hidden grayscale contrast-125">
                        <img src="/giovany_pared.png" 
                             alt="Consulta profesional" loading="lazy"
                             class="absolute -top-[5%] left-0 w-full h-[110%] object-cover parallax-element">
                    </div>
                    <!-- Decorative element -->
                    <div class="absolute -top-4 -right-4 w-24 h-24 border-t border-r border-[var(--color-accent-gold)]"></div>
                    <div class="absolute -bottom-4 -left-4 w-24 h-24 border-b border-l border-[var(--color-accent-gold)]"></div>
                </div>
                <div class="col-span-1 lg:col-span-7 lg:pl-12">
                    <span class="text-xs tracking-[0.2em] uppercase font-bold text-[var(--color-accent-gold)] block mb-6">Nuestro Compromiso</span>
                    <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif mb-8 leading-[1.1]" data-translate="straight-talk-title">
                        TRANQUILIDAD<br>A TRAVÉS DE<br><span class="italic font-light text-[var(--color-accent-gold)]">CERTEZA LEGAL.</span>
                    </h2>
                    <p class="text-lg text-gray-300 mb-10 font-light leading-relaxed max-w-xl" data-translate="straight-talk-desc">
                        No somos simplemente intermediarios; somos estrategas dedicados a blindar sus intereses. Proveemos una representación contundente con la discreción que exige el alto nivel.
                    </p>
                    <a href="https://api.whatsapp.com/send?phone=573104273850&text=Hola,%20quisiera%20información%20sobre%20sus%20servicios%20legales" target="_blank" rel="noopener noreferrer" class="border-b border-[var(--color-accent-gold)] text-[var(--color-accent-gold)] pb-1 hover:text-white hover:border-white transition-colors uppercase tracking-widest text-sm font-bold" data-translate="contact-now">
                        INICIAR CONVERSACIÓN
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Horizonte Institucional Section -->
    <section id="about" class="py-24 bg-[var(--color-primary-light)]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                
                <div class="col-span-1 lg:col-span-5 hidden lg:block">
                    <div class="sticky top-32">
                        <h2 class="text-5xl font-serif text-[var(--color-primary-dark)] mb-6 leading-tight" data-translate="institutional-title">
                            HORIZONTE<br>
                            <span class="italic text-[var(--color-accent-gold)]">INSTITUCIONAL</span>
                        </h2>
                        <img src="/logo2.png" alt="GE Abogados Shield" loading="lazy" class="w-48 h-48 object-contain opacity-20 mt-12 mix-blend-multiply">
                    </div>
                </div>

                <div class="col-span-1 lg:col-span-7 space-y-24">
                    <!-- Mobile Title -->
                    <div class="lg:hidden mb-12">
                        <h2 class="text-4xl font-serif text-[var(--color-primary-dark)] leading-tight" data-translate="institutional-title">
                            HORIZONTE <span class="italic text-[var(--color-accent-gold)]">INSTITUCIONAL</span>
                        </h2>
                    </div>

                    <!-- Misión -->
                    <div class="relative pl-8 md:pl-12">
                        <!-- Left vertical line decorative -->
                        <div class="absolute top-0 left-0 w-px h-full bg-[var(--color-primary-dark)]/20"></div>
                        <div class="absolute top-0 left-0 w-px h-16 bg-[var(--color-accent-gold)]"></div>
                        
                        <h3 class="text-xs tracking-[0.3em] font-bold text-[var(--color-primary-dark)] mb-6 uppercase" data-translate="mission-title">MISIÓN</h3>
                        <div class="text-[var(--color-text-body)] text-lg md:text-xl font-serif leading-relaxed" data-translate="mission-content">
                            <p class="mb-6">
                                Nuestra misión es erigirnos como un bastión en la defensa de los derechos, garantizando acceso a la justicia con rectitud implacable y equidad.
                            </p>
                            <p class="font-sans text-sm font-light text-gray-500">
                                Abordamos cada encargo combinando pasión, excelencia técnica y una lealtad inquebrantable a nuestra firma y nuestros clientes.
                            </p>
                        </div>
                    </div>
                    
                    <!-- Visión -->
                    <div class="relative pl-8 md:pl-12">
                        <div class="absolute top-0 left-0 w-px h-full bg-[var(--color-primary-dark)]/20"></div>
                        <div class="absolute top-0 left-0 w-px h-16 bg-[var(--color-accent-gold)]"></div>
                        
                        <h3 class="text-xs tracking-[0.3em] font-bold text-[var(--color-primary-dark)] mb-6 uppercase" data-translate="vision-title">VISIÓN</h3>
                        <div class="text-[var(--color-text-body)] text-lg md:text-xl font-serif leading-relaxed" data-translate="vision-content">
                            <p class="mb-6">
                                Para 2027, GE Abogados se consolidará como la firma insignia por su eficiencia de cirujano y capacidad de innovación legal.
                            </p>
                            <p class="font-sans text-sm font-light text-gray-500">
                                Evolucionamos constantemente a través del respeto sacro por el conocimiento jurídico, ofreciendo un servicio élite, personalizado y absolutamente transparente. La excelencia no es la meta, es el punto de partida.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="py-24 bg-white border-t border-[var(--color-primary-dark)]/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-20">
                <span class="text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-accent-gold)] block mb-4">Credenciales</span>
                <h2 class="text-4xl lg:text-5xl font-serif text-[var(--color-primary-dark)]" data-translate="testimonials-title">LO QUE DICEN NUESTROS CLIENTES</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
                <!-- Testimonial 1 -->
                <div class="relative">
                    <i class="fas fa-quote-left text-4xl text-[var(--color-primary-dark)]/5 absolute -top-6 -left-4"></i>
                    <p class="font-serif text-[var(--color-text-body)] text-lg italic leading-relaxed mb-8 relative z-10">
                        "Me sentí respaldada durante todo el proceso gracias a la profesionalidad y el riguroso conocimiento de su equipo. Esclarecieron mi caso con una precisión notable."
                    </p>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-full bg-gray-200 overflow-hidden grayscale">
                             <img src="https://lh3.googleusercontent.com/a-/ALV-UjUevJ_L_zKF50U18bXx0Bc6rcVSl_VLX0lAwSKLqTlTOcwoWbgYoQ=s33-c-rp-mo-br100" loading="lazy" alt="Client" class="w-full h-full object-cover">
                        </div>
                        <div>
                            <h4 class="text-xs uppercase tracking-widest font-bold text-[var(--color-primary-dark)]">Andrea Escobar</h4>
                            <p class="text-xs text-[var(--color-accent-gold)] font-medium">Cliente Privado</p>
                        </div>
                    </div>
                </div>
                
                <!-- Testimonial 2 -->
                <div class="relative">
                    <i class="fas fa-quote-left text-4xl text-[var(--color-primary-dark)]/5 absolute -top-6 -left-4"></i>
                    <p class="font-serif text-[var(--color-text-body)] text-lg italic leading-relaxed mb-8 relative z-10">
                        "Gracias a su dedicación y estrategia implacable, resolvieron mi caso con extrema rapidez, logrando un resultado excepcionalmente favorable."
                    </p>
                    <div class="flex items-center gap-4 mt-16 md:mt-8">
                        <div class="w-10 h-10 rounded-full bg-gray-200 overflow-hidden grayscale">
                             <img src="https://lh3.googleusercontent.com/a-/ALV-UjVf1Jgn7BxgogfsGt273D0q6tZQEWh4CznwTUHYamWQ4-k6YUqg=s33-c-rp-mo-br100" loading="lazy" alt="Client" class="w-full h-full object-cover">
                        </div>
                        <div>
                            <h4 class="text-xs uppercase tracking-widest font-bold text-[var(--color-primary-dark)]">Nicolle Rodriguez</h4>
                            <p class="text-xs text-[var(--color-accent-gold)] font-medium">Ejecutiva</p>
                        </div>
                    </div>
                </div>
                
                <!-- Testimonial 3 -->
                <div class="relative">
                    <i class="fas fa-quote-left text-4xl text-[var(--color-primary-dark)]/5 absolute -top-6 -left-4"></i>
                    <p class="font-serif text-[var(--color-text-body)] text-lg italic leading-relaxed mb-8 relative z-10">
                        "Trato 100% personalizado y élite. Tienen el talento de explicarte la estrategia jurídica más compleja con perfecta claridad. Los mejores del sector."
                    </p>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-full bg-gray-200 overflow-hidden grayscale">
                             <img src="https://lh3.googleusercontent.com/a-/ALV-UjVyzRMPhrJQ67H7Vx8bAItfbnbQ9lQ6vfyS9OEIFirH7Kh2ZIuICQ=s33-c-rp-mo-br100" loading="lazy" alt="Client" class="w-full h-full object-cover">
                        </div>
                        <div>
                            <h4 class="text-xs uppercase tracking-widest font-bold text-[var(--color-primary-dark)]">Natalia Rodriguez</h4>
                            <p class="text-xs text-[var(--color-accent-gold)] font-medium">Cliente Privado</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Blog Section -->
    <section id="blog" class="py-24 bg-[var(--color-primary-light)] border-t border-[var(--color-primary-dark)]/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16">
                <div>
                    <h2 class="text-4xl md:text-5xl font-serif text-[var(--color-primary-dark)]" data-translate="blog-title">INTELECTO &<br><span class="italic text-[var(--color-accent-gold)]">ANÁLISIS</span></h2>
                </div>
                <button class="mt-6 md:mt-0 font-bold uppercase tracking-widest text-xs border-b border-[var(--color-primary-dark)] pb-1 hover:text-[var(--color-accent-gold)] hover:border-[var(--color-accent-gold)] transition-colors" data-translate="view-all-posts">
                    Explorar Ediciones
                </button>
            </div>
            
            <div id="dynamic-blogs-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Fallback / Loading Skeletons -->
                <div class="animate-pulse flex flex-col items-center justify-center p-8 bg-black/5 aspect-[4/3]">
                    <span class="text-[var(--color-primary-dark)] font-serif italic text-xs">Cargando ediciones...</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Elevated CTA Section -->
    <section class="py-32 bg-[var(--color-primary-dark)] text-center relative overflow-hidden">
        <div class="absolute inset-0 noise-bg opacity-30 mix-blend-overlay"></div>
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <span class="text-xs tracking-[0.3em] uppercase font-bold text-[var(--color-accent-gold)] mb-8 block">Primer Contacto</span>
